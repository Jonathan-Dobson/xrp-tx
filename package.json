{
  "name": "xrpt",
  "version": "0.3.3",
  "description": "A standalone, zero-dependency transaction builder for the XRP Ledger",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run tests/transaction.test.ts",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "test:integration:offline": "node --experimental-vm-modules node_modules/.bin/vitest run tests/integration.offline.test.ts",
    "test:integration:testnet": "node --experimental-vm-modules node_modules/.bin/vitest run tests/integration.testnet.test.ts --testTimeout=30000",
    "test:docs": "node --experimental-vm-modules node_modules/.bin/vitest run tests/docs.test.ts",
    "test:all": "npm run test && npm run test:integration:offline && npm run test:integration:testnet",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "xrp",
    "xrpl",
    "transaction",
    "builder",
    "ripple",
    "ledger",
    "blockchain",
    "crypto"
  ],
  "author": "Jonathan Dobson",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.1",
    "xrpl": "^4.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jonathan-Dobson/xrpt.git"
  },
  "bugs": {
    "url": "https://github.com/Jonathan-Dobson/xrpt/issues"
  },
  "homepage": "https://github.com/Jonathan-Dobson/xrpt#readme"
}
